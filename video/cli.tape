Output public/cli.mp4
Set Shell "bash"
Set FontSize 24
Set Width 1500
Set Height 900
Set Padding 40
Set Theme { "name": "choko", "background": "#1A1815", "foreground": "#F0E8D6", "green": "#2E7D32", "cursor": "#C25B2D", "black": "#0E0D0B", "white": "#F0E8D6" }
Set TypingSpeed 40ms
Hide
Type "cd /Users/sockshead/develop/atender-application-engine"
Enter
Show
Sleep 600ms
Type "node .claude/scripts/validate-agent-fleet.mjs"
Sleep 700ms
Enter
Sleep 4500ms
