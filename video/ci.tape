Output public/ci.mp4
Set Shell "bash"
Set FontSize 26
Set Width 1500
Set Height 470
Set Padding 40
Set Theme { "name": "choko", "background": "#1A1815", "foreground": "#F0E8D6", "green": "#2E7D32", "cursor": "#C25B2D", "black": "#0E0D0B", "white": "#F0E8D6" }
Set TypingSpeed 45ms
Hide
Type "cd /Users/sockshead/develop/atender-application-engine"
Enter
Show
Sleep 500ms
Type "gh run view 27661967178  # the fleet's CI, green"
Sleep 700ms
Enter
Sleep 4500ms
